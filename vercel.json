{
  "buildCommand": "cd packages/backend && npx prisma generate && pnpm build && cd ../frontend && pnpm build",
  "outputDirectory": "packages/frontend/dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
